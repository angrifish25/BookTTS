{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TTS App",
  "version": "0.1.0",
  "identifier": "com.ttsapp.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TTS App",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self' blob:; connect-src 'self' https://huggingface.co;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Desktop TTS application with voice cloning",
    "longDescription": "A desktop text-to-speech application using Qwen3-TTS with voice cloning capabilities",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "14.0",
      "license": "MIT",
      "entitlements": null
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": true
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "scope": [
        "$APPDATA/**",
        "$CACHE/**",
        "$DOCUMENT/**",
        "$DOWNLOAD/**",
        "$AUDIO/**"
      ]
    }
  }
}